\definecolor{udcpink}{RGB}{0,51,202}
\definecolor{udcgray}{RGB}{100,100,100}
\definecolor{ficblue}{RGB}{50,110,118}

\newcommand{\paginaenblanco}{\mbox{}\thispagestyle{empty}\clearpage}
\newcommand{\dedicatoria}[1]{\thispagestyle{empty}\mbox{}\vfill\hfill\emph{#1}\vfill}
\newenvironment{agradecimientos}
               {\thispagestyle{empty}
                 \vspace*{175pt}
                 \subsubsection*{\centering Agradecimientos}}
               {\paginaenblanco}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% opcións titlesec                     %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\newcommand{\bigrule}{{\color{udcpink}\titlerule[0.5mm]}}
\titleformat{\chapter}[display]%
{\bfseries\Huge}%
{\filleft\Large\chaptertitlename \Large{} \thechapter}%
{0mm}{\filleft}[\vspace{0.5cm} \bigrule]

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% opcións fancyhdr                     %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\pagestyle{fancy}
\fancyhead{}
\fancyhead[LO]{{\small\leftmark}}
\fancyhead[RE]{{\small\nouppercase{\textsl{\rightmark}}}}
\fancyfoot{}
\fancyfoot[CE,CO]{\thepage}
\setlength{\headheight}{14pt}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% opcións setspace                     %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\onehalfspacing

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% opcións hyperref                     %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\hypersetup{
 colorlinks=true,
 linkcolor=ficblue,
 filecolor=ficblue,      
 urlcolor=ficblue,
 citecolor=ficblue
}
               
\endinput
